# ==========================================================================
# AI Agent 部署环境变量
# ==========================================================================
# 首次使用：cp .env.example .env，然后按需修改 .env 中的值。
# 如无特殊需求，使用默认值即可直接启动。
# ==========================================================================

# ---------- MySQL ----------
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=ai_agent
MYSQL_PORT=3306

# ---------- Redis ----------
REDIS_PORT=6379

# ---------- Milvus ----------
MILVUS_PORT=19530
MILVUS_METRICS_PORT=9091

# ---------- Nginx（仅 --profile full 时使用）----------
NGINX_PORT=80

# ---------- Backend（仅 --profile full 时使用）----------
BACKEND_PORT=8080
