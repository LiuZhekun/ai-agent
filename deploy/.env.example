# ==========================================================================
# AI Agent 部署环境变量
# ==========================================================================
# 首次使用：cp .env.example .env，然后按需修改 .env 中的值。
# 如无特殊需求，使用默认值即可直接启动。
# 如 Docker Hub 网络不稳定，可设置 DOCKERHUB_MIRROR（示例：docker.m.daocloud.io）。
# ==========================================================================

# ---------- 镜像源 ----------
# 默认 docker.io；可改为国内镜像加速域名，例如：
# DOCKERHUB_MIRROR=docker.m.daocloud.io
DOCKERHUB_MIRROR=docker.io

# ---------- 访问地址 ----------
# 用于安装脚本打印外网访问地址；如需外网访问请改为服务器 IP 或域名
ACCESS_HOST=127.0.0.1

# ---------- MySQL ----------
MYSQL_ROOT_PASSWORD=root
MYSQL_ROOT_HOST=%
MYSQL_DATABASE=ai_agent
MYSQL_PORT=3306

# ---------- Redis ----------
REDIS_PORT=6379

# ---------- Milvus ----------
# 可按需切换 Milvus 版本（例如: milvusdb/milvus:v2.4.13）
MILVUS_IMAGE=milvusdb/milvus:v2.4.10
# 外置依赖镜像（默认使用可用性更高的镜像仓库/Tag）
ETCD_IMAGE=quay.io/coreos/etcd:v3.5.15
MINIO_IMAGE=docker.io/minio/minio:RELEASE.2024-10-29T16-01-48Z
MILVUS_MINIO_ACCESS_KEY=minioadmin
MILVUS_MINIO_SECRET_KEY=minioadmin
MILVUS_PORT=19530
MILVUS_METRICS_PORT=9091
ETCD_PORT=2379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ---------- Nginx（仅 --profile full 时使用）----------
NGINX_PORT=80

# ---------- Backend（仅 --profile full 时使用）----------
BACKEND_PORT=8080
